#!/usr/bin/env python3
import sys
import os
import time
import subprocess

# Define the video formats you want to process
VIDEO_EXTENSIONS = {".mp4", ".mkv", ".avi", ".mov", ".webm"}


def print_info(msg):
    print(f"\033[96m[BATCH INFO]\033[0m {msg}")


def print_success(msg):
    print(f"\033[92m[BATCH SUCCESS]\033[0m {msg}")


def print_skip(msg):
    print(f"\033[93m[BATCH SKIP]\033[0m {msg}")


def print_metric(msg):
    print(f"\033[95m[BATCH METRIC]\033[0m {msg}")


def print_error(msg):
    print(f"\033[91m[BATCH ERROR]\033[0m {msg}")


def format_duration(seconds):
    if seconds < 60:
        return f"{seconds:.1f}s"
    m, s = divmod(int(seconds), 60)
    h, m = divmod(m, 60)
    if h > 0:
        return f"{h}h {m:02d}m {s:02d}s"
    return f"{m}m {s:02d}s"


def main():
    if len(sys.argv) < 2:
        print_error("Usage: autosub <directory_path>")
        sys.exit(1)

    print(sys.argv[0], sys.argv[1])
    target_dir = os.path.abspath(sys.argv[1])
    print(target_dir)
    if not os.path.isdir(target_dir):
        print_error(f"Directory not found: {target_dir}")
        sys.exit(1)

    print_info(f"Scanning directory: {target_dir}")

    all_files = os.listdir(target_dir)
    video_files = [
        f for f in all_files if os.path.splitext(f)[1].lower() in VIDEO_EXTENSIONS
    ]

    if not video_files:
        print_info("No video files found in the specified directory.")
        return

    print_info(f"Found {len(video_files)} video file(s). Starting batch process...\n")

    processed_count = 0
    skipped_count = 0
    error_log = []  # List to track any files that fail
    file_times = []  # Track per-file processing times
    to_process = len(video_files) - sum(
        1 for f in video_files
        if os.path.exists(os.path.join(target_dir, f"{os.path.splitext(f)[0]}.srt"))
    )

    batch_start = time.time()

    for idx, video_file in enumerate(sorted(video_files)):
        video_path = os.path.join(target_dir, video_file)
        base_name = os.path.splitext(video_file)[0]
        srt_path = os.path.join(target_dir, f"{base_name}.srt")

        # Skip if already processed
        if os.path.exists(srt_path):
            print_skip(
                f"{idx + 1}/{len(video_files)}: '{video_file}' already has an .srt file. Skipping."
            )
            skipped_count += 1
            continue

        # ETA based on files processed so far
        eta_str = ""
        if file_times:
            avg_time = sum(file_times) / len(file_times)
            remaining_files = to_process - len(file_times)
            eta_str = f" | ETA: {format_duration(avg_time * remaining_files)}"

        print_info(f"{idx + 1}/{len(video_files)}: Processing: '{video_file}'{eta_str}")

        try:
            file_start = time.time()
            result = subprocess.run(["autosub_single", video_path])
            file_elapsed = time.time() - file_start

            if result.returncode == 0:
                processed_count += 1
                file_times.append(file_elapsed)
                print_metric(f"'{video_file}' completed in {format_duration(file_elapsed)}")
            else:
                print_error(f"autosub failed on '{video_file}' after {format_duration(file_elapsed)}.")
                error_log.append(
                    f"Failed on: '{video_file}' (Exit code: {result.returncode})"
                )
        except FileNotFoundError:
            fatal_msg = "FATAL: The 'autosub_single' command was not found in PATH."
            print_error(fatal_msg)
            error_log.append(fatal_msg)
            break

        print("-" * 50)

    # Final Output
    batch_elapsed = time.time() - batch_start
    print("\n" + "=" * 50)
    print_success(
        f"Batch run complete! Processed: {processed_count} | Skipped: {skipped_count} | "
        f"Failed: {len(error_log)}"
    )
    print_metric(f"Total batch time: {format_duration(batch_elapsed)}")
    if file_times:
        avg = sum(file_times) / len(file_times)
        print_metric(f"Average per file: {format_duration(avg)}")
    print("=" * 50)

    # Print the consolidated error summary if any occurred
    if error_log:
        print(
            "\n\033[91m[ERROR SUMMARY]\033[0m The following issues occurred during the run:"
        )
        for error_msg in error_log:
            print(f" - {error_msg}")
        print("=" * 50)


if __name__ == "__main__":
    main()
